# --- Site URL (SEO, Open Graph, sitemap) ---
# Production: https://estudiocolibri.es
NEXT_PUBLIC_SITE_URL=https://estudiocolibri.es

# --- Google Tag Manager ---
# Container ID from https://tagmanager.google.com (format GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- Resend (contact form) ---
# 1. Create account: https://resend.com
# 2. API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public contact email (mailto + visible on site). Use your brand inbox in production.
NEXT_PUBLIC_CONTACT_EMAIL=hola@estudiocolibri.es

# Form delivery inbox (server only). Optional: defaults to NEXT_PUBLIC_CONTACT_EMAIL.
# With onboarding@resend.dev you can ONLY send to your Resend account email.
# CONTACT_INBOX_EMAIL=you@resend-account-email.com

CONTACT_FROM_EMAIL=onboarding@resend.dev
# Production: CONTACT_FROM_EMAIL=Estudio Colibrí <hola@estudiocolibri.es>

# --- Cloudflare Turnstile (bot protection) ---
# Dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
# Test keys (always pass): site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
